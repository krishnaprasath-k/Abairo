---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Strategic Advisory | abairo">
  <section class="section-padding-lg bg-dark text-center">
    <div class="container animate-fade-up">
      <h1 class="heading-xl mb-6 text-white">The Growth Partner Who'll Call You Out — and Call the Shots</h1>
      <p class="body-lg max-w-3xl mx-auto">
        We don't play cheerleader. We come in like a board-level partner, strip away the fluff, sharpen your offers, and give you a growth plan that works in the real world.
      </p>
    </div>
  </section>

  <section class="section-padding bg-light">
    <div class="container flex-col items-center">
      <h2 class="heading-lg mb-8 text-center">Who This Is For</h2>
      <div class="grid grid-cols-3 gap-6 w-full">
        <div class="card card-dark text-center hover-lift">
          <h3 class="font-bold text-lg mb-2 text-white">Brands doing ₹5–₹50 lakh/year ready to double or triple that.</h3>
        </div>
        <div class="card card-dark text-center hover-lift">
          <h3 class="font-bold text-lg mb-2 text-white">Founders tired of "ideas" and ready for strategies that are built to execute.</h3>
        </div>
        <div class="card card-dark text-center hover-lift">
          <h3 class="font-bold text-lg mb-2 text-white">Businesses open to performance-based partnerships where we share the upside.</h3>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="heading-lg">What's Included & How It Works</h2>
      </div>

      <div class="grid grid-cols-2 gap-12 max-w-4xl mx-auto">
        
        <div class="flex-col gap-6">
          <h3 class="heading-md">What's Included</h3>
          <ul class="flex-col gap-4">
            <li class="bg-light p-4 rounded-sm">
              <strong class="text-primary block mb-1">Business & Sales Audit</strong>
              <span class="body-sm">Find the bottlenecks, the leaks, and the missed opportunities.</span>
            </li>
            <li class="bg-light p-4 rounded-sm">
              <strong class="text-primary block mb-1">Offer & Pricing Reinvention</strong>
              <span class="body-sm">Make what you sell impossible to say no to.</span>
            </li>
            <li class="bg-light p-4 rounded-sm">
              <strong class="text-primary block mb-1">Quarterly Growth Roadmap</strong>
              <span class="body-sm">Exactly what to do, when to do it, and how to track it.</span>
            </li>
            <li class="bg-light p-4 rounded-sm">
              <strong class="text-primary block mb-1">Execution Oversight</strong>
              <span class="body-sm">Regular reviews to keep momentum and adjust fast.</span>
            </li>
            <li class="bg-light p-4 rounded-sm border border-primary">
              <strong class="text-primary block mb-1">Revenue-Share Partnerships (optional)</strong>
              <span class="body-sm">We bring strategy + leads, you deliver — profits split fairly.</span>
            </li>
          </ul>
        </div>

        <div class="flex-col gap-6">
          <h3 class="heading-md">How It Works</h3>
          <div class="card border">
            <h4 class="heading-sm mb-2">1. Audit</h4>
            <p class="body-sm mb-6">We dig into numbers, processes, and positioning like an investor.</p>
            
            <h4 class="heading-sm mb-2">2. Blueprint</h4>
            <p class="body-sm mb-6">You get a battle-ready plan for offers, sales, and marketing.</p>
            
            <h4 class="heading-sm mb-2">3. Execution</h4>
            <p class="body-sm mb-6">We stay involved to ensure it's implemented right.</p>
            
            <h4 class="heading-sm mb-2">4. Scale Decisions</h4>
            <p class="body-sm">Shift gears fast when something's working.</p>
          </div>
        </div>
        
      </div>
    </div>
  </section>

  <section class="section-padding bg-dark text-center">
    <div class="container max-w-4xl mx-auto">
      <h2 class="heading-md mb-6 text-white">The Result</h2>
      <p class="heading-sm mb-4 text-gray-300 font-normal">
        No more playing small, chasing low-ticket clients, or guessing what works.
      </p>
      <p class="body-lg mb-8 italic">
        You get a brand, an offer, and a sales process that make scaling feel inevitable.
      </p>
      <div class="flex items-center justify-center gap-6 flex-wrap">
        <p class="heading-md text-primary">From: ₹50,000/mo or 10-40% rev share</p>
        <a href="/contact" class="btn btn-primary">Let's Build the Next Level →</a>
      </div>
    </div>
  </section>
</Layout>
