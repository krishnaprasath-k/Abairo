---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="abairo System | abairo">
  <section class="section-padding-lg bg-dark text-center">
    <div class="container animate-fade-up">
      <h1 class="heading-xl mb-6 text-white">90 Days to a Brand That Sells Without Begging</h1>
      <p class="body-lg max-w-3xl mx-auto">
        We don’t just “make you a website.” We engineer your online presence so it looks expensive, ranks on Google, and makes strangers want to buy — before you even say hello.
      </p>
    </div>
  </section>

  <section class="section-padding">
    <div class="container grid grid-cols-2 gap-8 items-center">
      <div class="flex-col gap-6">
        <h2 class="heading-md">Who We Work With</h2>
        <p class="body-lg">
          Premium fashion labels. Fine jewellery houses. Luxury home décor brands. Wellness retreats. High-value service providers.
        </p>
        <div class="p-6 bg-light rounded-sm border-l-4" style="border-left-color: var(--color-primary);">
          <p class="body-md font-semibold text-text">If your brand deserves to be taken seriously, we make sure it happens.</p>
        </div>
      </div>

      <div class="card bg-surface hover-lift border">
        <h3 class="heading-md mb-6">What’s Inside</h3>
        <ul class="flex-col gap-4">
          <li>
            <strong class="text-primary text-lg block mb-1">A Site That Sells for You</strong>
            <p class="body-sm">Shopify or WordPress, built for speed, SEO, and conversions.</p>
          </li>
          <li>
            <strong class="text-primary text-lg block mb-1">Google Visibility</strong>
            <p class="body-sm">Strategic keywords, on-page SEO, metadata, indexing — no more hiding on page 7.</p>
          </li>
          <li>
            <strong class="text-primary text-lg block mb-1">A Content Playbook</strong>
            <p class="body-sm">90 days of Instagram + LinkedIn post angles that position you as the go-to name in your space.</p>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section-padding bg-light">
    <div class="container">
      <div class="text-center mb-8">
        <h2 class="heading-lg">The Roadmap</h2>
      </div>
      
      <div class="grid grid-cols-2 gap-6 max-w-3xl mx-auto">
        <div class="card hover-lift text-center">
          <span class="text-overline">Week 1–2</span>
          <h4 class="font-bold text-lg">Deep-dive brand audit + positioning call.</h4>
        </div>
        <div class="card hover-lift text-center">
          <span class="text-overline">Week 3–6</span>
          <h4 class="font-bold text-lg">Website build & SEO foundation locked in.</h4>
        </div>
        <div class="card hover-lift text-center">
          <span class="text-overline">Week 7–8</span>
          <h4 class="font-bold text-lg">Content plan creation + brand visuals guidance.</h4>
        </div>
        <div class="card hover-lift text-center">
          <span class="text-overline">Week 9–12</span>
          <h4 class="font-bold text-lg">Refinements + launch.</h4>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-dark text-center">
    <div class="container max-w-3xl">
      <h2 class="heading-md mb-6 text-white">The Result</h2>
      <p class="body-lg mb-8">
        A digital presence that commands attention, attracts buyers, and sets you apart from 95% of your competitors still playing amateur online.
      </p>
      <div class="flex items-center justify-center gap-6 flex-wrap">
        <p class="heading-md text-primary">Starting at: ₹60,000</p>
        <a href="/contact" class="btn btn-primary">Build My Growth System →</a>
      </div>
    </div>
  </section>
</Layout>
