---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Growth Boosters | abairo">
  <section class="section-padding-lg bg-dark text-center">
    <div class="container animate-fade-up">
      <h1 class="heading-xl mb-6 text-white">Because 'Just Having a Website' Won't Pay Your Bills</h1>
      <p class="body-lg max-w-3xl mx-auto">
        The right audience, the right message, the right time — delivered like clockwork. We turn your brand from a static presence into a sales engine.
      </p>
    </div>
  </section>

  <section class="section-padding bg-light">
    <div class="container flex-col items-center">
      <h2 class="heading-lg mb-8 text-center">Who This Is For</h2>
      <div class="grid grid-cols-3 gap-6 w-full">
        <div class="card text-center hover-lift">
          <h3 class="font-bold text-lg mb-2">Brands with a decent online presence but underwhelming sales.</h3>
        </div>
        <div class="card text-center hover-lift">
          <h3 class="font-bold text-lg mb-2">Businesses launching something new and needing buzz yesterday.</h3>
        </div>
        <div class="card text-center hover-lift">
          <h3 class="font-bold text-lg mb-2">Service providers who want their calendars booked with ready-to-buy clients.</h3>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container">
      <div class="text-center mb-8">
        <span class="text-overline">What We Do</span>
        <h2 class="heading-lg">No Generic, Spray-and-Pray Tactics</h2>
      </div>

      <div class="grid grid-cols-3 gap-8">
        <div class="card card-dark flex-col gap-4">
          <h3 class="heading-sm text-primary">Elite Lead Generation</h3>
          <ul class="body-sm flex-col gap-2">
            <li>- HNI targeting for luxury services, real estate, and high-ticket offers.</li>
            <li>- Precision LinkedIn prospecting with messaging that actually gets replies.</li>
            <li>- Cold email flows that read like warm introductions.</li>
            <li>- WhatsApp follow-up sequences designed to close, not just "check in."</li>
          </ul>
        </div>
        <div class="card card-dark flex-col gap-4">
          <h3 class="heading-sm text-primary">Content Engine</h3>
          <ul class="body-sm flex-col gap-2">
            <li>- Instagram feeds that make your audience want to own your product.</li>
            <li>- LinkedIn positioning that gets you into the right conversations.</li>
            <li>- YouTube topic scripts that turn viewers into inbound leads.</li>
          </ul>
        </div>
        <div class="card card-dark flex-col gap-4">
          <h3 class="heading-sm text-primary">Paid Ad Domination</h3>
          <ul class="body-sm flex-col gap-2">
            <li>- We run ads where your buyers already are — and only on creatives that have earned their keep.</li>
            <li>- Retargeting to make sure no warm lead slips away.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-light">
    <div class="container">
      <h2 class="heading-lg text-center mb-8">Roadmap to Results</h2>
      <div class="grid grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="card text-center hover-lift border-t-4" style="border-top-color: var(--color-primary);">
          <span class="text-overline">Month 1</span>
          <p class="font-bold">Build & launch campaigns — targeting, creatives, automation.</p>
        </div>
        <div class="card text-center hover-lift border-t-4" style="border-top-color: var(--color-primary);">
          <span class="text-overline">Month 2</span>
          <p class="font-bold">Strip out what’s underperforming, push budget into what’s working.</p>
        </div>
        <div class="card text-center hover-lift border-t-4" style="border-top-color: var(--color-primary);">
          <span class="text-overline">Month 3</span>
          <p class="font-bold">Scale winners until you feel the operational pinch (in a good way).</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-dark text-center">
    <div class="container max-w-4xl mx-auto">
      <h2 class="heading-md mb-6 text-white">The Result</h2>
      <p class="heading-sm mb-4 text-gray-300 font-normal">
        More high-intent traffic. More qualified conversations. More deals closed.
      </p>
      <p class="body-lg mb-8 italic">
        All without you lifting a finger after kickoff.
      </p>
      <div class="flex items-center justify-center gap-6 flex-wrap">
        <p class="heading-md text-primary">From: ₹25,000–₹80,000/month</p>
        <a href="/contact" class="btn btn-primary">Switch My Growth On →</a>
      </div>
    </div>
  </section>
</Layout>
